# Domaine servi par Caddy (Let's Encrypt auto).
# Utilise "localhost" pour tester sans certificat.
DOMAIN=example.com

# Credentials PostgreSQL du container (modifier avant le premier démarrage)
POSTGRES_USER=clairimmo
POSTGRES_PASSWORD=clairimmo
POSTGRES_DB=claire_immo

# Source des prix DVF : "database" (PostgreSQL local) ou "cerema" (API côté client)
NEXT_PUBLIC_DVF_SOURCE=database
NEXT_PUBLIC_DEBUG=false

# Token Atmo France (optionnel)
ATMO_API_TOKEN=
